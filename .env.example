# ===== Domain for nginx + SSL =====
# Locally — оставь localhost (поднимется самоподписной сертификат через init-ssl.sh).
# На сервере — реальный домен без https://, например: stratchatella.ru
# SSL-сертификат подкладывается руками в volume "letsencrypt".
DOMAIN=localhost

# ===== Cassandra =====
CASSANDRA_HOSTS=cassandra
CASSANDRA_PORT=9042
CASSANDRA_KEYSPACE=zoomarket
CASSANDRA_USER=cassandra
CASSANDRA_PASSWORD=cassandra
CASSANDRA_REPLICATION_FACTOR=1

# ===== Redis =====
REDIS_HOST=redis
REDIS_PORT=6379

# ===== Backend (FastAPI) =====
JWT_SECRET=please-change-me-to-a-long-random-string-32+chars
JWT_ALGORITHM=HS256
JWT_EXPIRES_MINUTES=10080
SEED_ON_START=true
# Allow same origin (nginx делает proxy с того же домена)
BACKEND_CORS_ORIGINS=https://localhost,http://localhost,https://stratchatella.ru

# ===== Frontend =====
# Относительный путь — браузер сам подставит текущий домен (через nginx)
VITE_API_URL=/api

# ===== Mock payment =====
PAYMENT_PROVIDER=mock
PAYMENT_AUTOAPPROVE=true

# ===== MinIO (S3-compatible object storage) =====
S3_ENDPOINT=http://minio:9000
# Относительный путь — изображения отдаются через nginx /storage/...
S3_PUBLIC_URL=/storage
S3_BUCKET=zoomarket-media
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
